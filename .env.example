# 复制为 .env 并按需修改
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# 数据库；切到 Postgres 时填 postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./data/thyroid_quiz.db

# session cookie 签名密钥；生产环境务必换成 32+ 字节随机字符串
SECRET_KEY=change-me-please-use-a-long-random-string

# session 有效期（小时）
SESSION_HOURS=72

# 上传图片存储根目录
STORAGE_DIR=./storage

# 单图最大字节数（默认 20MB）
MAX_UPLOAD_BYTES=20971520

# 初始 admin（首次启动 init_admin 脚本会用到）
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123456
INIT_ADMIN_DISPLAY_NAME=超级管理员
